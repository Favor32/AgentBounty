# .env.example — copy to .env.local (frontend) and .env (backend)

# === BACKEND ===
PORT=3001

# Trustless Work
TRUSTLESS_WORK_API_KEY= 
TRUSTLESS_WORK_API_URL= 

# Wallet that acts as the "AI agent" (funded Sepolia wallet)
AGENT_PRIVATE_KEY= 
AGENT_WALLET_ADDRESS= 

# GitHub webhook
GITHUB_WEBHOOK_SECRET=

GROQ_API_KEY=

# Sepolia RPC
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/

# === FRONTEND (.env.local) ===
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
NEXT_PUBLIC_CHAIN_ID=11155111


# ── AgentBounty Environment Variables ─────────────────────────────────────
# Copy this file to apps/api/.env and fill in your values.

# Server
PORT=3001

# Trustless Work
# Get your key at: https://docs.trustlesswork.com/trustless-work/introduction/developer-resources/request-api-key
TRUSTLESS_WORK_API_KEY=
TRUSTLESS_WORK_API_URL=https://api.trustlesswork.com

# Agent wallet (Sepolia) — this wallet FUNDS the escrow
# Generate one at: https://app.safe.global or use MetaMask export
AGENT_PRIVATE_KEY=0x
AGENT_WALLET_ADDRESS=0x

# Arbitrator wallet — resolves disputes (can be same as agent for MVP)
ARBITRATOR_WALLET_ADDRESS=0x

# Claude AI
# Get at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-

# GitHub webhook secret — set this in your GitHub repo Settings > Webhooks
# Generate with: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=

# Sepolia RPC (for viem client if needed)
# Get free key at: https://infura.io or https://alchemy.com
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY

# ── Frontend (.env.local in apps/web/) ────────────────────────────────────

NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_CHAIN_ID=11155111
